#!/bin/sh

set -eu

ACTION="${1:-diff}"

if [ "$#" -gt 0 ]; then
  shift
fi

ALLOW_DESTRUCTIVE=false

while [ "$#" -gt 0 ]; do
  case "$1" in
  --allow-destructive)
    ALLOW_DESTRUCTIVE=true
    shift
    ;;
  --)
    shift
    break
    ;;
  *)
    break
    ;;
  esac
done

DATABASE_NAME="${POSTGRES_DB:-postgres}"
DATABASE_USER="${POSTGRES_USER:-postgres}"
SCHEMA_DIR="${SCHEMA_DIR:-/docker-entrypoint-initdb.d}"

export PGPASSWORD="${POSTGRES_PASSWORD:-}"

COMBINED_SCHEMA="$(mktemp)"
SCHEMA_FILE_LIST="$(mktemp)"

cleanup() {
  rm -f "$COMBINED_SCHEMA" "$SCHEMA_FILE_LIST"
}

trap cleanup EXIT INT TERM

find "$SCHEMA_DIR" \
  -type f \
  -name '*.sql' \
  -print |
  sort >"$SCHEMA_FILE_LIST"

if [ ! -s "$SCHEMA_FILE_LIST" ]; then
  echo "No .sql files found under: $SCHEMA_DIR" >&2
  exit 1
fi

while IFS= read -r schema_file; do
  printf '\n-- Source: %s\n\n' "$schema_file" >>"$COMBINED_SCHEMA"
  cat "$schema_file" >>"$COMBINED_SCHEMA"
  printf '\n' >>"$COMBINED_SCHEMA"
done <"$SCHEMA_FILE_LIST"

run_psqldef() {
  if [ "$ALLOW_DESTRUCTIVE" = "true" ]; then
    set -- --enable-drop "$@"
  fi

  psqldef \
    --host=127.0.0.1 \
    --user="$DATABASE_USER" \
    "$DATABASE_NAME" \
    --file="$COMBINED_SCHEMA" \
    "$@"
}

case "$ACTION" in
diff | dry-run)
  run_psqldef --dry-run "$@"
  ;;

check)
  run_psqldef --check "$@"
  ;;

apply)
  run_psqldef --apply "$@"
  ;;

export)
  psqldef \
    --host=127.0.0.1 \
    --user="$DATABASE_USER" \
    "$DATABASE_NAME" \
    --export \
    "$@"
  ;;

*)
  echo "Usage: schema-sync {diff|dry-run|check|apply|export} [--allow-destructive] [psqldef options]" >&2
  exit 1
  ;;
esac
